# Copia este archivo a ".env" (sin ".example") y llena tus datos reales.
# ".env" está en .gitignore: nunca se sube al repo.
# La contraseña original que se filtró en el chat debe estar rotada en Atlas
# antes de usarla aquí.

MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/
MONGO_DB=seengo
MONGO_COLL=sign_events

# --- Opcionales, solo para el servidor en vivo (consumidor/servidor.py) ---
# SEENGO_PORT=8000          # puerto donde escucha el tablero
# SEENGO_DIAS=60            # ventana rodante en días que consulta a Mongo
# SEENGO_REFRESH_MIN=30     # cada cuántos minutos vuelve a leer Mongo
