{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  "python.envFile": "${workspaceFolder}/.env",
  "terminal.integrated.env.windows": {
    "PYTHONUTF8": "1"
  },
  "files.exclude": {
    "**/__pycache__": true
  },
  "search.exclude": {
    "**/.venv": true
  },
  "[python]": {
    "editor.tabSize": 4
  }
}
